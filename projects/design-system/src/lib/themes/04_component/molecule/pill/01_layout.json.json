        "token_family_docs": {
          "$description": {
            "$type": "other",
            "$value": "Layout tokens for the Pill molecule — spacing, border-radius, surface, color, icon size, and minimum height."
          },
          "$extensions": {
            "oblique": {
              "kind": {
                "$type": "other",
                "$value": "token_family_docs"
              },
              "export": {
                "$type": "other",
                "$value": "false"
              }
            }
          }
        },
        "spacing": {
          "padding": {
            "vertical": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.element.xs.px}",
              "$description": "Top and bottom padding  – for medium size pills."
            },
            "horizontal": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.spacing.xs.px}",
              "$description": "Left and right padding  – for medium size pills."
            }
          },
          "gap": {
            "$type": "spacing",
            "$value": "{ob.s.dimension.dynamic.ui_scale.element.xl.px}",
            "$description": "Horizontal gap between icon and text label  – for medium size pills."
          }
        },
        "border_radius": {
          "default": {
            "$type": "borderRadius",
            "$value": "{ob.s.border_radius.rounded}",
            "$description": "Standard pills in Oblique."
          }
