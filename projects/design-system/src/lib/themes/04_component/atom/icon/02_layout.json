{
  "ob": {
    "c": {
      "icon": {
        "token_family_docs": {
          "$description": {
            "$type": "other",
            "$value": "Layout and size tokens for the Icon atom — static, component, and inline-text size variants."
          },
          "$extensions": {
            "oblique": {
              "kind": {
                "$type": "other",
                "$value": "token_family_docs"
              },
              "export": {
                "$type": "other",
                "$value": "false"
              }
            }
          }
        },
        "static": {
          "size": {
            "xs": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.xs.rem}",
              "$description": "16px fixed. Does not react to ui_scale mode."
            },
            "sm": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.sm.rem}",
              "$description": "20px fixed. Does not react to ui_scale mode."
            },
            "md": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.md.rem}",
              "$description": "Default. 24px fixed. Does not react to any size mode."
            },
            "lg": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.xl.rem}",
              "$description": "32px fixed. Does not react to ui_scale mode."
            }
          }
        },
        "ui_scale": {
          "size": {
            "xs": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.spacing.xs.rem}",
              "$description": "Smallest icon size. Reacts to ui_scale mode."
            },
            "sm": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.spacing.sm.rem}",
              "$description": "Small icon size. Reacts to ui_scale mode."
            },
            "md": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.spacing.md.rem}",
              "$description": "Default icon size. Reacts to ui_scale mode."
            },
            "lg": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.spacing.xl.rem}",
              "$description": "Large icon size. Reacts to ui_scale mode."
            }
          }
        },
        "typography_context": {
          "size": {
            "body": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.typography_context.md}",
              "$description": "Inline icon size for body text only. Reacts to typography_context mode."
            }
          }
        },
        "inline_text": {
          "body": {
            "spacing": {
              "vertical": {
                "offset": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.micro.sm.px}",
                  "$description": "Upward optical baseline offset for inline icons with adjacent capital letters. Fixed at 2px (= 0.125em at 16px base). Figma does not support em units — devs should implement as 0.125em in CSS so the offset scales proportionally with the adjacent text size. Does not react to any mode."
                }
              }
            }
          }
        }
      }
    }
  }
}