{
  "ob": {
    "c": {
      "icon": {
        "static": {
          "size": {
            "xs": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.component_size.spacing.xs.rem}",
              "$description": "16px fixed. Does not react to component_size mode."
            },
            "sm": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.component_size.spacing.sm.rem}",
              "$description": "20px fixed. Does not react to component_size mode."
            },
            "md": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.component_size.spacing.md.rem}",
              "$description": "Default. 24px fixed. Does not react to any size mode."
            },
            "lg": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.component_size.spacing.xl.rem}",
              "$description": "32px fixed. Does not react to component_size mode."
            }
          }
        },
        "component": {
          "size": {
            "xs": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.component_size.spacing.xs.rem}",
              "$description": "Smallest icon size. Reacts to component_size mode."
            },
            "sm": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.component_size.spacing.sm.rem}",
              "$description": "Small icon size. Reacts to component_size mode."
            },
            "md": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.component_size.spacing.md.rem}",
              "$description": "Default icon size. Reacts to component_size mode."
            },
            "lg": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.component_size.spacing.xl.rem}",
              "$description": "Large icon size. Reacts to component_size mode."
            }
          }
        },
        "inline_text": {
          "size": {
            "body": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.dynamic.typography_context.md}",
              "$description": "Inline icon size for body text only. Reacts to typography_context mode."
            }
          },
          "body": {
            "spacing": {
              "vertical": {
                "offset": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.component_size.micro.sm.px}",
                  "$description": "Upward optical baseline offset for inline icons with adjacent capital letters. 2px fixed; does not react to any mode."
                }
              }
            }
          }
        }
      }
    }
  }
}