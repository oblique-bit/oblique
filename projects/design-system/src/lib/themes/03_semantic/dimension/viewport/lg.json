{
  "ob": {
    "s": {
      "dimension": {
        "viewport": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Min/max width for the page-container component in the Figma library, at the lg (large) viewport. Mode-scoped: resolves to the lg range when the lg viewport mode is active."
            },
            "$extensions": {
              "oblique": {
                "kind": {
                  "$type": "other",
                  "$value": "token_family_docs"
                },
                "export": {
                  "$type": "other",
                  "$value": "false"
                }
              }
            }
          },
          "min_width": {
            "$type": "dimension",
            "$value": "{ob.g.mode_collection.viewport.lg.range.from}",
            "$description": "Minimum width of a page container in the lg viewport."
          },
          "max_width": {
            "$type": "dimension",
            "$value": "{ob.g.mode_collection.viewport.lg.range.to}",
            "$description": "Maximum width of a page container in the lg viewport."
          }
        }
      }
    }
  }
}
