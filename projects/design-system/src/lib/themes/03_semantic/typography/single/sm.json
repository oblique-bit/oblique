{
  "ob": {
    "s": {
      "dynamic": {
        "token_family_docs": {
          "$description": {
            "$type": "other",
            "$value": "Individual typography tokens for the Small component size mode."
          }
        },
        "font_size": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic font-size scale — values scale with the active ui_scale mode (sm/md/lg) via the typography multiplier."
            }
          },
          "xs": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.100} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "sm": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.200} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "md": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.300} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "lg": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.400} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "xl": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.500} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "2xl": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.600} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "3xl": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.700} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "4xl": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.800} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "5xl": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.900} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "base": {
            "$type": "fontSizes",
            "$value": "{ob.p.font_size_rem.300} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          }
        },
        "line_height": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic line-height scale — paired with the dynamic font-size scale. Scales with ui_scale (sm/md/lg)."
            }
          },
          "xs": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.300} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "sm": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.400} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "md": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.500} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "lg": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.600} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "xl": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.800} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "2xl": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.1100} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "3xl": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.1300} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          },
          "4xl": {
            "$type": "lineHeights",
            "$value": "{ob.p.line_height_rem.1400} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}"
          }
        },
        "paragraph_spacing": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic paragraph-spacing scale — half the matching dynamic line-height, so paragraph rhythm scales with ui_scale."
            }
          },
          "xs": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.xs} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "sm": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.sm} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "md": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.md} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "lg": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.lg} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "xl": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.xl} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "2xl": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.2xl} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "3xl": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.3xl} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          },
          "4xl": {
            "$type": "paragraphSpacing",
            "$value": "({ob.s.dynamic.line_height.4xl} * {ob.g.mode_collection.ui_scale.multiplier.typography.sm}) / 2"
          }
        },
        "spacing": {
          "heading": {
            "top": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.static.ui_scale.none.px}",
              "$description": "Standard spacing above H1 is none to use vertical space."
            },
            "top_after_p": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.static.ui_scale.container.md.px}",
              "$description": "SPecial spacing above H1 after a paragraph"
            },
            "bottom": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.static.ui_scale.element.md.px}"
            }
          },
          "paragraph": {
            "bottom": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.static.density.6xl.rem}"
            }
          }
        },
        "font_weight": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic font weight tokens — identical numeric mapping to the static set, exposed in the ui_scale collection for parity."
            }
          },
          "regular": {
            "$type": "fontWeights",
            "$value": "{ob.p.font_weight.400}"
          },
          "medium": {
            "$type": "fontWeights",
            "$value": "{ob.p.font_weight.500}"
          },
          "semiBold": {
            "$type": "fontWeights",
            "$value": "{ob.p.font_weight.600}"
          },
          "bold": {
            "$type": "fontWeights",
            "$value": "{ob.p.font_weight.700}"
          },
          "extraBold": {
            "$type": "fontWeights",
            "$value": "{ob.p.font_weight.800}"
          }
        },
        "text_decoration": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic text-decoration tokens — primarily for links. Mirrors the static set."
            }
          },
          "link": {
            "emphasis_high": {
              "$type": "textDecoration",
              "$value": "{ob.p.text_decoration.underline}",
              "$description": "Standard text-link has an underline."
            },
            "emphasis_low": {
              "$type": "textDecoration",
              "$value": "{ob.p.text_decoration.none}",
              "$description": "Use where it is obvious that it is link and no need for additional typographical emphasis such as underline."
            }
          }
        },
        "letter_spacing_rem": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic letter spacing (rem) — tracking values authored in rem in the ui_scale collection."
            }
          },
          "superNarrow": {
            "$type": "letterSpacing",
            "$value": "-0.03rem",
            "$description": "For font sizes 4xl, 5xl, 6xl for a more compact visual appearance. \nHas to be convertered to em!"
          },
          "narrower": {
            "$type": "letterSpacing",
            "$value": "-0.01rem",
            "$description": "For font size 3x for a more compact visual appearance.\nHas to be convertered to em!"
          },
          "narrow": {
            "$type": "letterSpacing",
            "$value": "0.005rem",
            "$description": "For font sizes 2xl for a more compact visual appearance.\nHas to be convertered to em!\n"
          },
          "normal": {
            "$type": "letterSpacing",
            "$value": "auto",
            "$description": "Default letter spacing for body and labels.\nHas to be convertered to em!"
          },
          "wide": {
            "$type": "letterSpacing",
            "$value": "0.5%",
            "$description": "For buttons for a more confortable visual appearance\nHas to be convertered to em!"
          }
        },
        "letter_spacing_px": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Dynamic letter spacing (px) — tracking values authored in px in the ui_scale collection."
            }
          },
          "superNarrow": {
            "$type": "letterSpacing",
            "$value": "{ob.p.letter_spacing_px.neg_150}",
            "$description": "For font sizes 4xl, 5xl, 6xl for a more compact visual appearance. \nHas to be convertered to em!"
          },
          "narrower": {
            "$type": "letterSpacing",
            "$value": "{ob.p.letter_spacing_px.neg_100}",
            "$description": "For font size 3x for a more compact visual appearance.\nHas to be convertered to em!"
          },
          "narrow": {
            "$type": "letterSpacing",
            "$value": "{ob.p.letter_spacing_px.neg_50}",
            "$description": "For font sizes 2xl for a more compact visual appearance.\nHas to be convertered to em!\n"
          },
          "normal": {
            "$type": "letterSpacing",
            "$value": "{ob.p.letter_spacing_px.0}",
            "$description": "Default letter spacing for body and labels.\nHas to be convertered to em!"
          },
          "wide": {
            "$type": "letterSpacing",
            "$value": "{ob.p.letter_spacing_px.50}",
            "$description": "For buttons for a more confortable visual appearance\nHas to be convertered to em!"
          }
        }
      }
    }
  }
}
