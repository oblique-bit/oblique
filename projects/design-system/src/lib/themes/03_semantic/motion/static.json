{
  "ob": {
    "s": {
      "motion": {
        "easing": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Mode-independent easing curve tokens — standard, entrance, exit, and emphasis. Not affected by motion mode."
            },
            "$extensions": {
              "oblique": {
                "kind": {
                  "$type": "other",
                  "$value": "token_family_docs"
                },
                "export": {
                  "$type": "other",
                  "$value": "false"
                }
              }
            }
          },
          "standard": {
            "$type": "cubicBezier",
            "$value": "{ob.p.motion.easing.ease_out}",
            "$description": "Default easing for most UI animations"
          },
          "entrance": {
            "$type": "cubicBezier",
            "$value": "{ob.p.motion.easing.ease_out}",
            "$description": "For elements entering the screen"
          },
          "exit": {
            "$type": "cubicBezier",
            "$value": "{ob.p.motion.easing.ease_in}",
            "$description": "For elements leaving the screen"
          },
          "emphasis": {
            "$type": "cubicBezier",
            "$value": "{ob.p.motion.easing.ease_in_out}",
            "$description": "For attention-drawing animations"
          }
        }
      }
    }
  }
}