{
  "ob": {
    "h": {
      "hr": {
        "token_family_docs": {
          "$description": "Tokens for the HTML hr element — height and color (subtle, default, strong).",
          "$extensions": {
            "oblique": {
              "kind": "token_family_docs",
              "export": false
            }
          }
        },
        "size": {
          "height": {
            "$type": "dimension",
            "$value": "{ob.s.border_width.xs}"
          }
        },
        "color": {
          "subtle": {
            "$type": "color",
            "$value": "{ob.s.color.neutral.border.subtle.inversity_normal}"
          },
          "default": {
            "$type": "color",
            "$value": "{ob.s.color.neutral.border.medium.inversity_normal}"
          },
          "strong": {
            "$type": "color",
            "$value": "{ob.s.color.neutral.border.strong.inversity_normal}"
          }
        }
      }
    }
  }
}
