{
  "ob": {
    "h": {
      "button": {
        "typography": {
          "token_family_docs": {
            "$description": {
              "$type": "other",
              "$value": "Typography tokens for the HTML button element — font-size, font-weight, and line-height."
            },
            "$extensions": {
              "oblique": {
                "kind": {
                  "$type": "other",
                  "$value": "token_family_docs"
                },
                "export": {
                  "$type": "other",
                  "$value": "false"
                }
              }
            }
          },
          "text_label": {
            "font_size": {
              "$type": "fontSizes",
              "$value": "{ob.s.dynamic.font_size.md}",
              "$description": "Font size that scales with typography multiplier"
            },
            "line_height": {
              "$type": "lineHeights",
              "$value": "{ob.s.dynamic.line_height.xs}",
              "$description": "Line height that scales with typography multiplier"
            },
            "letter_spacing": {
              "$type": "letterSpacing",
              "$value": "{ob.s.dynamic.letter_spacing_px.normal}",
              "$description": "Letter spacing for button text labels"
            },
            "font_family": {
              "$type": "fontFamilies",
              "$value": "{ob.s.static.font_family.body}",
              "$description": "Font family for button text labels - consistent across all sizes"
            },
            "font_weight": {
              "$type": "fontWeights",
              "$value": "{ob.s.dynamic.font_weight.medium}",
              "$description": "Font weight for button text labels - consistent across all sizes"
            },
            "text_decoration": {
              "$type": "textDecoration",
              "$value": "{ob.s.static.text_decoration.link.emphasis_low}",
              "$description": "No text decoration for button labels"
            },
            "text_transform": {
              "$type": "textCase",
              "$value": "{ob.s.static.text_case.none}",
              "$description": "No text transformation for button labels"
            }
          }
        }
      }
    }
  }
}