{
  "ob": {
    "h": {
      "button": {
        "token_family_docs": {
          "$description": {
            "$type": "other",
            "$value": "Layout tokens for the HTML button element — spacing, size, and border-radius."
          },
          "$extensions": {
            "oblique": {
              "kind": {
                "$type": "other",
                "$value": "token_family_docs"
              },
              "export": {
                "$type": "other",
                "$value": "false"
              }
            }
          }
        },
        "dynamic": {
          "label_icon": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.dynamic.ui_scale.element.sm.rem}"
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.dynamic.ui_scale.element.xl.rem}"
                }
              },
              "gap": {
                "$type": "spacing",
                "$value": "{ob.s.dimension.dynamic.ui_scale.element.sm.px}"
              }
            },
            "container": {
              "size": {
                "min_height": {
                  "$type": "sizing",
                  "$value": "{ob.s.dimension.dynamic.ui_scale.container.xs.px}",
                  "$description": "old {ob.s.dimension.dynamic.ui_scale.spacing.md.rem}\n"
                }
              }
            },
            "icon_size": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.md.rem}",
              "$description": "Standard proportional size of the icon inside the label_icon button subcomponent."
            }
          },
          "icon_only": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.dynamic.ui_scale.element.sm.rem}"
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.dynamic.ui_scale.element.sm.rem}"
                }
              }
            }
          },
          "remove": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.none.rem}",
                  "$description": "Remove button requires zero padding."
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.none.rem}",
                  "$description": "Remove button requires zero padding."
                }
              }
            }
          },
          "icon": {
            "size": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.md.rem}"
            }
          }
        },
        "remove": {
          "icon": {
            "asset": {
              "$type": "asset",
              "$value": "cancel-circle",
              "$description": "Default icon asset for button.remove."
            }
          }
        },
        "border_radius": {
          "$type": "borderRadius",
          "$value": "{ob.s.border_radius.md}",
          "$description": "Standard border radius for button components - consistent across all sizes"
        },
        "border_width": {
          "$type": "borderWidth",
          "$value": "{ob.s.border_width.xs}",
          "$description": "Tinest border width possible for buttons for aesthetics and functionality: differentiation between secondary and tertiary. Static token, not reacting on changing component-size modes."
        },
        "static": {
          "label_icon": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.element.sm.rem}"
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.element.xl.rem}"
                }
              },
              "gap": {
                "$type": "spacing",
                "$value": "{ob.s.dimension.static.ui_scale.element.sm.px}"
              }
            },
            "container": {
              "size": {
                "min_height": {
                  "$type": "sizing",
                  "$value": "{ob.s.dimension.static.ui_scale.container.xs.px}",
                  "$description": "old {ob.s.dimension.dynamic.ui_scale.spacing.md.rem}\n"
                }
              }
            },
            "icon_size": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.md.rem}",
              "$description": "Standard proportional size of the icon inside the label_icon button subcomponent."
            }
          },
          "icon_only": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.element.sm.rem}"
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.element.sm.rem}"
                }
              }
            }
          },
          "remove": {
            "spacing": {
              "padding": {
                "vertical": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.none.rem}",
                  "$description": "Remove button requires zero padding."
                },
                "horizontal": {
                  "$type": "spacing",
                  "$value": "{ob.s.dimension.static.ui_scale.none.rem}",
                  "$description": "Remove button requires zero padding."
                }
              }
            }
          },
          "icon": {
            "size": {
              "$type": "sizing",
              "$value": "{ob.s.dimension.static.ui_scale.spacing.md.rem}"
            }
          }
        }
      }
    }
  }
}