{
  "ob": {
    "h": {
      "button": {
        "shadow": {
          "token_family_docs": {
            "$description": "Shadow tokens for the HTML button element.",
            "$extensions": {
              "oblique": {
                "kind": "token_family_docs",
                "export": false
              }
            }
          },
          "enabled": {
            "$type": "boxShadow",
            "$value": "{ob.s.shadow.none}",
            "$description": "No shadow on enabled state"
          },
          "hover": {
            "$type": "boxShadow",
            "$value": "{ob.s.shadow.xl}",
            "$description": "Elevation effect on hover"
          },
          "focus": {
            "$type": "boxShadow",
            "$value": "{ob.s.shadow.none}",
            "$description": "No shadow on focus state"
          },
          "pressed": {
            "$type": "boxShadow",
            "$value": "{ob.s.shadow.none}",
            "$description": "No shadow on pressed state"
          },
          "disabled": {
            "$type": "boxShadow",
            "$value": "{ob.s.shadow.none}",
            "$description": "No shadow on disabled state"
          }
        }
      }
    }
  }
}
