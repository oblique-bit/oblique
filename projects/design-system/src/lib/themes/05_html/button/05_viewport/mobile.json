{
  "ob": {
    "h": {
      "button": {
        "token_family_docs": {
          "$description": {
            "$type": "other",
            "$value": "Viewport-specific layout tokens for the HTML button element at the mobile breakpoint."
          },
          "$extensions": {
            "oblique": {
              "kind": {
                "$type": "other",
                "$value": "token_family_docs"
              },
              "export": {
                "$type": "other",
                "$value": "false"
              }
            }
          }
        },
        "container": {
          "spacing": {
            "gap": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.element.xl.px}",
              "$description": "Button gap for mobile viewport - tighter spacing for touch interaction"
            }
          }
        },
        "touch_target": {
          "min_size": {
            "$type": "dimension",
            "$value": "{ob.s.dimension.static.density.9xl.px}",
            "$description": "Enhanced mobile touch target minimum size for better accessibility"
          }
        }
      }
    }
  }
}