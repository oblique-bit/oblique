{
  "ob": {
    "h": {
      "button": {
        "motion": {
          "token_family_docs": {
            "$description": "Motion tokens for the HTML button element — transition duration and easing.",
            "$extensions": {
              "oblique": {
                "kind": "token_family_docs",
                "export": false
              }
            }
          },
          "duration": {
            "$type": "duration",
            "$value": "{ob.s.motion.duration.smooth}",
            "$description": "Button transition duration"
          },
          "easing": {
            "$type": "cubicBezier",
            "$value": "{ob.s.motion.easing.standard}",
            "$description": "Button transition easing"
          }
        }
      }
    }
  }
}
