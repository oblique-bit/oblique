              "$description": "button_vd1 label font size (replicates ob.h.button - static md, no ui_scale modes)"
            },
            "font_weight": {
              "$type": "fontWeights",
              "$value": "{ob.s.static.font_weight.medium}",
              "$description": "button_vd1 label font weight (replicates ob.h.button)"
            },
            "line_height": {
              "$type": "lineHeights",
              "$value": "{ob.s.static.line_height.xs}",
              "$description": "button_vd1 label line height (replicates ob.h.button - static, no scale modes)"
            },
            "letter_spacing": {
              "$type": "letterSpacing",
              "$value": "{ob.s.static.letter_spacing_px.normal}",
              "$description": "button_vd1 label letter spacing (replicates ob.h.button)"
            },
            "text_decoration": {
              "$type": "textDecoration",
