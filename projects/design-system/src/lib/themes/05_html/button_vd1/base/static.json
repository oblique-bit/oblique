          },
          "layer_2": {
            "color": {
              "$type": "color",
              "$value": "{ob.p.color.cobalt_alpha.100}",
              "$description": "button_vd1 drop-shadow layer 2 colour - constant (replicates ob.s.shadow.xl second layer, cobalt.900 @ 10%). Geometry is interaction-driven."
