            },
            "horizontal": {
              "$type": "spacing",
              "$value": "{ob.s.dimension.dynamic.ui_scale.element.xl.px}",
              "$description": "button_vd1 horizontal padding (replicates ob.h.button label_icon - dynamic ui_scale, scales with the ui_scale collection; .px variant so Figma binds pixels not rem)"
            }
          },
          "min_height": {
            "$type": "sizing",
