{
  "ob": {
    "g": {
      "viewport": {
        "breakpoint": {
          "xs": {
            "$type": "dimension",
            "$value": "0px",
            "$description": "Lower boundary of the xs (extra-small) viewport range."
          },
          "sm": {
            "$type": "dimension",
            "$value": "480px",
            "$description": "Lower boundary of the sm (small) viewport range."
          },
          "md": {
            "$type": "dimension",
            "$value": "768px",
            "$description": "Lower boundary of the md (medium) viewport range."
          },
          "lg": {
            "$type": "dimension",
            "$value": "1024px",
            "$description": "Lower boundary of the lg (large) viewport range."
          },
          "xl": {
            "$type": "dimension",
            "$value": "1440px",
            "$description": "Lower boundary of the xl (extra-large) viewport range."
          },
          "2xl": {
            "$type": "dimension",
            "$value": "1920px",
            "$description": "Lower boundary of the 2xl (extra-extra-large) viewport range."
          }
        },
        "range": {
          "xs": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.xs}",
              "$description": "xs range start, inclusive: 0px."
            },
            "to": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.sm}",
              "$description": "xs range end, exclusive: width < 480px."
            }
          },
          "sm": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.sm}",
              "$description": "sm range start, inclusive: 480px."
            },
            "to": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.md}",
              "$description": "sm range end, exclusive: width < 768px."
            }
          },
          "md": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.md}",
              "$description": "md range start, inclusive: 768px."
            },
            "to": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.lg}",
              "$description": "md range end, exclusive: width < 1024px."
            }
          },
          "lg": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.lg}",
              "$description": "lg range start, inclusive: 1024px."
            },
            "to": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.xl}",
              "$description": "lg range end, exclusive: width < 1440px."
            }
          },
          "xl": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.xl}",
              "$description": "xl range start, inclusive: 1440px."
            },
            "to": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.2xl}",
              "$description": "xl range end, exclusive: width < 1920px."
            }
          },
          "2xl": {
            "from": {
              "$type": "dimension",
              "$value": "{ob.g.viewport.breakpoint.2xl}",
              "$description": "2xl range start, inclusive: 1920px. Open-ended, no upper boundary."
            }
          }
        }
      }
    }
  }
}
